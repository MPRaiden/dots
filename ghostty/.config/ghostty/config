theme = TokyoNight Night

font-family = Ioskeley ono 
font-size = 11

cursor-style = block
cursor-style-blink = true

mouse-hide-while-typing = true

shell-integration-features = no-cursor,no-sudo

copy-on-select = true

window-padding-x = 10 
window-padding-y = 20

confirm-close-surface = false

keybind = ctrl+t=new_tab
keybind = ctrl+[=previous_tab
keybind = ctrl+]=next_tab
keybind = ctrl+q=close_tab
keybind = ctrl+s=start_search
