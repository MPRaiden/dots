theme = Catppuccin Mocha
window-theme = ghostty

font-family = Ioskeley Mono 
font-size = 11

cursor-style = block
cursor-style-blink = true

mouse-hide-while-typing = true

shell-integration-features = no-cursor,no-sudo

copy-on-select = true

window-padding-x = 10 
window-padding-y = 20

confirm-close-surface = false

keybind = ctrl+t=new_tab
keybind = ctrl+[=previous_tab
keybind = ctrl+]=next_tab
keybind = ctrl+q=close_tab
keybind = ctrl+a>v=new_split:right
keybind = ctrl+a>h=goto_split:left
keybind = ctrl+a>l=goto_split:right
keybind = ctrl+s=start_search

gtk-wide-tabs = false
